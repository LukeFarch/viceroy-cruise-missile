# Generated per-deployment secrets — regenerated by `make configs`
configs/**/key.pem
configs-s2/**/key.pem
configs/**/*.pem
configs-s2/**/*.pem

# SSH keys dropped into the keys/ mount
keys/*.pem
keys/*_key
keys/*_rsa
keys/*_ed25519
keys/id_*
!keys/*.pub
!keys/.gitkeep

# WireGuard output from scripts/wg-gen.sh
wireguard/server.conf
wireguard/peers/
wireguard/*.key
wireguard/*.priv

# Operator environment files
.env
.env.local
*.env.local

# Built Go binaries (committed binaries at repo root are legacy — drop them)
/boomer
/controller
/sensor
/configgen
/scenario
/scoreboard

# Go build cache / tooling
*.test
*.out
*.prof
vendor/

# Python helpers cache
docs/comp-materials/__pycache__/
**/__pycache__/
*.pyc

# Editor / OS noise
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# Docker volumes created by compose (if bind-mounted locally)
/data/
