# Copy to .env and edit before running `docker compose up`. Nothing in this
# file is secret on its own, but .env is .gitignored because your real
# deployment values (endpoints, chosen ports) should not leak into a public
# fork.

# --- Host bind for published ports ---
# Default 127.0.0.1 keeps everything on loopback; behind WireGuard you'll
# typically set BIND_ADDR=10.8.0.1 so only tunnel peers can reach SSH and the
# scoreboard. Set to 0.0.0.0 ONLY if the host is isolated.
BIND_ADDR=127.0.0.1

# --- Attack-station SSH ---
SSH_HOST_PORT=2222

# --- Scoreboards ---
SCOREBOARD_PORT=8080
S2_SCOREBOARD_PORT=8081

# --- WireGuard (used by scripts/wg-gen.sh, not by docker-compose directly) ---
# Public endpoint your peers will dial. host:port form.
WG_ENDPOINT=range.example.com:51820
WG_SERVER_PORT=51820
